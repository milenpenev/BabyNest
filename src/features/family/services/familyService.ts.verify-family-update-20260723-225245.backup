import { requireSupabase } from "../../../lib/supabase/supabaseClient";
import type { FamilyRole } from "../model/family.types";

export type CloudInvitationStatus =
  "pending" | "accepted" | "revoked" | "expired";

export interface CloudFamilyInvitation {
  id: string;
  familyId: string;
  invitedBy: string;
  email: string | null;
  displayName: string | null;
  role: Exclude<FamilyRole, "owner">;
  inviteCode: string;
  status: CloudInvitationStatus;
  expiresAt: string;
  acceptedBy: string | null;
  acceptedAt: string | null;
  createdAt: string;
  updatedAt: string;
}

interface FamilyInvitationRow {
  id: string;
  family_id: string;
  invited_by: string;
  email: string | null;
  display_name: string | null;
  role: Exclude<FamilyRole, "owner">;
  invite_code: string;
  status: CloudInvitationStatus;
  expires_at: string;
  accepted_by: string | null;
  accepted_at: string | null;
  created_at: string;
  updated_at: string;
}

export interface CloudFamily {
  id: string;
  name: string;
  role: FamilyRole;
  createdAt: string | null;
  updatedAt: string | null;
}

interface FamilyRow {
  id: string;
  name: string | null;
  created_at?: string | null;
  updated_at?: string | null;
}

interface CurrentFamilyMemberRow {
  family_id: string;
  role: FamilyRole;
}

export interface CloudFamilyMember {
  familyId: string;
  profileId: string;
  role: FamilyRole;
  displayName: string;
  email: string | null;
  avatarUrl: string | null;
  subscriptionPlan: "free" | "premium";
  createdAt: string | null;
}

interface FamilyMemberRpcRow {
  family_id: string;
  profile_id: string;
  role: FamilyRole;
  status: string;
  display_name: string | null;
  email: string | null;
  subscription_plan: string | null;
  created_at: string | null;
}

interface CreateInvitationInput {
  familyId: string;
  email?: string;
  displayName?: string;
  role: Exclude<FamilyRole, "owner">;
}

function createInviteCode() {
  return crypto.randomUUID().replaceAll("-", "").slice(0, 10).toUpperCase();
}

function mapInvitation(row: FamilyInvitationRow): CloudFamilyInvitation {
  return {
    id: row.id,
    familyId: row.family_id,
    invitedBy: row.invited_by,
    email: row.email,
    displayName: row.display_name,
    role: row.role,
    inviteCode: row.invite_code,
    status: row.status,
    expiresAt: row.expires_at,
    acceptedBy: row.accepted_by,
    acceptedAt: row.accepted_at,
    createdAt: row.created_at,
    updatedAt: row.updated_at,
  };
}

export const familyService = {
  async createFamily(familyName: string): Promise<CloudFamily> {
    const normalizedName = familyName.trim();

    if (normalizedName.length < 2) {
      throw new Error("FAMILY_NAME_TOO_SHORT");
    }

    const supabase = requireSupabase();

    const { data, error } = await supabase.rpc("create_family", {
      p_name: normalizedName,
    });

    if (error) {
      throw error;
    }

    const result = Array.isArray(data) ? data[0] : data;

    if (!result?.family_id) {
      throw new Error("FAMILY_CREATION_FAILED");
    }

    return {
      id: result.family_id as string,
      name: (result.family_name as string) || normalizedName,
      role: "owner",
      createdAt: null,
      updatedAt: null,
    };
  },

  async listMyFamilies(): Promise<CloudFamily[]> {
    const supabase = requireSupabase();

    const {
      data: { user },
      error: userError,
    } = await supabase.auth.getUser();

    if (userError) {
      throw userError;
    }

    if (!user) {
      return [];
    }

    const { data, error } = await supabase.rpc("list_my_families");

    if (error) {
      throw error;
    }

    const rows = (data ?? []) as Array<{
      family_id: string;
      family_name: string | null;
      member_role: string | null;
      family_created_at: string | null;
      family_updated_at: string | null;
    }>;

    return rows.map((row) => ({
      id: row.family_id,
      name: row.family_name?.trim() || "BabyNest Family",
      role:
        row.member_role === "owner" ||
        row.member_role === "parent" ||
        row.member_role === "babysitter" ||
        row.member_role === "viewer"
          ? row.member_role
          : "viewer",
      createdAt: row.family_created_at,
      updatedAt: row.family_updated_at,
    }));
  },

  async updateFamilyName(


    familyId: string,


    name: string,


  ): Promise<void> {


    const supabase = requireSupabase();


    const normalizedName = name.trim();



    if (!normalizedName) {


      throw new Error("Family name cannot be empty.");


    }



    const { error } = await supabase


      .from("families")


      .update({


        name: normalizedName,


        updated_at: new Date().toISOString(),


      })


      .eq("id", familyId);



    if (error) {


      throw error;


    }


  },



  async listMembers(familyId: string): Promise<CloudFamilyMember[]> {
    const normalizedFamilyId = familyId.trim();

    if (!normalizedFamilyId) {
      return [];
    }

    const supabase = requireSupabase();

    const { data, error } = await supabase.rpc("list_family_members", {
      p_family_id: normalizedFamilyId,
    });

    if (error) {
      throw error;
    }

    const rows = (data ?? []) as FamilyMemberRpcRow[];

    return rows.map((row) => ({
      familyId: row.family_id,
      profileId: row.profile_id,
      role: row.role,
      displayName: row.display_name?.trim() || "Family member",
      email: row.email,
      avatarUrl: null,
      subscriptionPlan:
        row.subscription_plan === "premium" ? "premium" : "free",
      createdAt: row.created_at,
    }));
  },

  async createInvitation(input: CreateInvitationInput) {
    const supabase = requireSupabase();

    const {
      data: { user },
      error: userError,
    } = await supabase.auth.getUser();

    if (userError) {
      throw userError;
    }

    if (!user) {
      throw new Error("Authentication is required to create an invitation.");
    }

    const normalizedEmail = input.email?.trim().toLowerCase() || null;

    const normalizedDisplayName = input.displayName?.trim() || null;

    const expiresAt = new Date(
      Date.now() + 7 * 24 * 60 * 60 * 1000,
    ).toISOString();

    const { data, error } = await supabase
      .from("family_invitations")
      .insert({
        family_id: input.familyId,
        invited_by: user.id,
        email: normalizedEmail,
        display_name: normalizedDisplayName,
        role: input.role,
        invite_code: createInviteCode(),
        status: "pending",
        expires_at: expiresAt,
      })
      .select(
        [
          "id",
          "family_id",
          "invited_by",
          "email",
          "display_name",
          "role",
          "invite_code",
          "status",
          "expires_at",
          "accepted_by",
          "accepted_at",
          "created_at",
          "updated_at",
        ].join(","),
      )
      .single<FamilyInvitationRow>();

    if (error) {
      throw error;
    }

    return mapInvitation(data);
  },

  async listInvitations(familyId: string) {
    const supabase = requireSupabase();

    const { data, error } = await supabase
      .from("family_invitations")
      .select(
        [
          "id",
          "family_id",
          "invited_by",
          "email",
          "display_name",
          "role",
          "invite_code",
          "status",
          "expires_at",
          "accepted_by",
          "accepted_at",
          "created_at",
          "updated_at",
        ].join(","),
      )
      .eq("family_id", familyId)
      .order("created_at", {
        ascending: false,
      })
      .returns<FamilyInvitationRow[]>();

    if (error) {
      throw error;
    }

    return data.map(mapInvitation);
  },

  async listPendingInvitations(familyId: string) {
    const invitations = await this.listInvitations(familyId);

    const now = Date.now();

    return invitations.filter(
      (invitation) =>
        invitation.status === "pending" &&
        new Date(invitation.expiresAt).getTime() > now,
    );
  },

  async revokeInvitation(invitationId: string) {
    const supabase = requireSupabase();

    const { data, error } = await supabase
      .from("family_invitations")
      .update({
        status: "revoked",
        updated_at: new Date().toISOString(),
      })
      .eq("id", invitationId)
      .select(
        [
          "id",
          "family_id",
          "invited_by",
          "email",
          "display_name",
          "role",
          "invite_code",
          "status",
          "expires_at",
          "accepted_by",
          "accepted_at",
          "created_at",
          "updated_at",
        ].join(","),
      )
      .single<FamilyInvitationRow>();

    if (error) {
      throw error;
    }

    return mapInvitation(data);
  },

  async acceptInvitation(inviteCode: string) {
    const supabase = requireSupabase();

    const normalizedCode = inviteCode.trim().toUpperCase();

    if (!normalizedCode) {
      throw new Error("Invitation code is required.");
    }

    const { data, error } = await supabase.rpc("accept_family_invitation", {
      p_invite_code: normalizedCode,
    });

    if (error) {
      throw error;
    }

    const result = Array.isArray(data) ? data[0] : data;

    if (!result) {
      throw new Error("The invitation could not be accepted.");
    }

    return {
      familyId: result.family_id as string,
      invitationId: result.invitation_id as string,
      role: result.assigned_role as Exclude<FamilyRole, "owner">,
    };
  },

  async getInvitationByCode(inviteCode: string) {
    const supabase = requireSupabase();

    const normalizedCode = inviteCode.trim().toUpperCase();

    if (!normalizedCode) {
      return null;
    }

    const { data, error } = await supabase
      .from("family_invitations")
      .select(
        [
          "id",
          "family_id",
          "invited_by",
          "email",
          "display_name",
          "role",
          "invite_code",
          "status",
          "expires_at",
          "accepted_by",
          "accepted_at",
          "created_at",
          "updated_at",
        ].join(","),
      )
      .eq("invite_code", normalizedCode)
      .maybeSingle<FamilyInvitationRow>();

    if (error) {
      throw error;
    }

    return data ? mapInvitation(data) : null;
  },
};
